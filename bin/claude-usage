#!/usr/bin/env bash
set -euo pipefail

# Resolve library paths
# Nix install: @LIB_DIR@ and @VIEWS_DIR@ are substituted at build time
# Git install: use relative paths from this script's location
# Follow symlinks so relative paths work when invoked via a symlink
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT_SOURCE" ]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
    # Handle relative symlink targets
    [[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"

LIB_DIR="@LIB_DIR@"
VIEWS_DIR="@VIEWS_DIR@"

if [ "$LIB_DIR" = "@""LIB_DIR""@" ]; then
    # Not substituted — running from source/git clone
    LIB_DIR="${SCRIPT_DIR}/../lib"
    VIEWS_DIR="${SCRIPT_DIR}/../views"
fi

# Check dependencies
for _dep in jq curl; do
    if ! command -v "$_dep" >/dev/null 2>&1; then
        echo "Error: '$_dep' is required but not found. Install it and try again." >&2
        exit 1
    fi
done
unset _dep

# Source libraries
# shellcheck source=../lib/util.sh
source "${LIB_DIR}/util.sh"
# shellcheck source=../lib/fetch.sh
source "${LIB_DIR}/fetch.sh"
# shellcheck source=../lib/history.sh
source "${LIB_DIR}/history.sh"
# shellcheck source=../lib/render.sh
source "${LIB_DIR}/render.sh"
# shellcheck source=../lib/update.sh
source "${LIB_DIR}/update.sh"

# Parse global flags
CU_OPT_NO_COLOR=""
CU_OPT_NO_FETCH=""
CU_OPT_WIDTH=""
CU_OPT_HOURS=""
CU_OPT_BRAILLE=""
CU_OPT_MULTILINE=""
CU_OPT_TIER=""

# Configurable defaults (override via env vars or CLI flags)
# CU_ETA_WINDOWS is deprecated — map to CU_WINDOWS for backward compat
CU_WINDOWS="${CU_WINDOWS:-${CU_ETA_WINDOWS:-five_hour,seven_day}}"
CU_MODULES="${CU_MODULES:-}"  # default set per mode in statusline
CU_SPARKLINE_TYPE="${CU_SPARKLINE_TYPE:-braille}"
CU_BAR_WIDTH="${CU_BAR_WIDTH:-10}"

# ETA defaults
CU_ETA_5H_AVG="${CU_ETA_5H_AVG:-1}"
CU_ETA_7D_AVG="${CU_ETA_7D_AVG:-24}"

# Color overrides (users can set these to custom ANSI codes)
CU_COLOR_SPARKLINE="${CU_COLOR_SPARKLINE:-${CU_PURPLE}}"
CU_COLOR_RATE="${CU_COLOR_RATE:-${CU_ORANGE}}"
CU_COLOR_ETA="${CU_COLOR_ETA:-${CU_AQUA}}"
CU_COLOR_RESET="${CU_COLOR_RESET:-${CU_DIM}}"
CU_COLOR_RESET_ICON="${CU_COLOR_RESET_ICON:-${CU_PURPLE}}"
CU_COLOR_LABEL="${CU_COLOR_LABEL:-${CU_DIM}}"
CU_COLOR_DIR="${CU_COLOR_DIR:-${CU_AQUA}}"
CU_COLOR_BRANCH="${CU_COLOR_BRANCH:-${CU_GREEN}}"
CU_COLOR_WARN="${CU_COLOR_WARN:-${CU_RED}}"

# Update check
CU_UPDATE_CHECK="${CU_UPDATE_CHECK:-1}"
CU_UPDATE_TTL="${CU_UPDATE_TTL:-3600}"

parse_flags() {
    while [ $# -gt 0 ]; do
        case "$1" in
            --no-color)
                CU_OPT_NO_COLOR=1
                CU_NO_COLOR=1
                ;;
            --no-fetch)
                CU_OPT_NO_FETCH=1
                ;;
            --tier)
                [ $# -ge 2 ] || { echo "Error: --tier requires a value (short or long)" >&2; return 1; }
                shift; CU_OPT_TIER="$1"
                ;;
            --data-dir)
                [ $# -ge 2 ] || { echo "Error: --data-dir requires a path" >&2; return 1; }
                shift; CU_DATA_DIR="$1"
                CU_HISTORY_SHORT="${CU_DATA_DIR}/history-short.jsonl"
                CU_HISTORY_LONG="${CU_DATA_DIR}/history-long.jsonl"
                mkdir -p "$CU_DATA_DIR"
                ;;
            --cache-dir)
                [ $# -ge 2 ] || { echo "Error: --cache-dir requires a path" >&2; return 1; }
                shift; CU_CACHE_DIR="$1"
                CU_CACHE_FILE="${CU_CACHE_DIR}/api-response.json"
                mkdir -p "$CU_CACHE_DIR"
                ;;
            --width)
                [ $# -ge 2 ] || { echo "Error: --width requires a number" >&2; return 1; }
                shift; CU_OPT_WIDTH="$1"
                ;;
            --hours)
                [ $# -ge 2 ] || { echo "Error: --hours requires a number" >&2; return 1; }
                shift; CU_OPT_HOURS="$1"
                ;;
            --braille)
                CU_OPT_BRAILLE=1
                ;;
            --multiline)
                CU_OPT_MULTILINE=1
                ;;
            --eta-windows|--windows)
                [ $# -ge 2 ] || { echo "Error: $1 requires a value" >&2; return 1; }
                shift; CU_WINDOWS="$1"
                ;;
            --modules)
                [ $# -ge 2 ] || { echo "Error: --modules requires a value" >&2; return 1; }
                shift; CU_MODULES="$1"
                ;;
            --sparkline-type)
                [ $# -ge 2 ] || { echo "Error: --sparkline-type requires a value (braille or block)" >&2; return 1; }
                shift; CU_SPARKLINE_TYPE="$1"
                ;;
            --bar-width)
                [ $# -ge 2 ] || { echo "Error: --bar-width requires a number" >&2; return 1; }
                shift; CU_BAR_WIDTH="$1"
                ;;
            *)
                echo "Unknown flag: $1" >&2
                return 1
                ;;
        esac
        shift
    done
}

cmd_show() {
    parse_flags "$@"
    # shellcheck source=../views/dashboard.sh
    source "${VIEWS_DIR}/dashboard.sh"
    cu_view_dashboard
}

cmd_statusline() {
    parse_flags "$@"
    # shellcheck source=../views/statusline.sh
    source "${VIEWS_DIR}/statusline.sh"
    cu_view_statusline
}

cmd_sparkline() {
    parse_flags "$@"
    local hours="${CU_OPT_HOURS:-168}"
    local width="${CU_OPT_WIDTH:-40}"
    local tier="${CU_OPT_TIER:-long}"
    local field="seven_day"
    [ "$tier" = "short" ] && field="five_hour"
    local mode=""
    [ "${CU_OPT_BRAILLE:-}" = "1" ] && mode="braille"
    if [ "${CU_OPT_NO_FETCH:-}" != "1" ]; then
        if cu_fetch; then
            local cache_data
            cache_data=$(cu_read_cache)
            [ -n "$cache_data" ] && cu_history_record "$cache_data"
        fi
    fi
    cu_sparkline_from_history "$field" "$hours" "$width" "$mode" "$tier"
    echo
}

cmd_eta() {
    parse_flags "$@"
    if [ "${CU_OPT_NO_FETCH:-}" != "1" ]; then
        if cu_fetch; then
            local cache_data
            cache_data=$(cu_read_cache)
            [ -n "$cache_data" ] && cu_history_record "$cache_data"
        fi
    fi
    local any_output=""
    local _eta_win
    for _eta_win in ${CU_WINDOWS//,/ }; do
        local _eta_field="" _eta_avg="" _eta_label=""
        case "$_eta_win" in
            five_hour) _eta_field="five_hour"; _eta_avg="${CU_ETA_5H_AVG:-3}"; _eta_label="5-Hour Window" ;;
            seven_day) _eta_field="seven_day"; _eta_avg="${CU_ETA_7D_AVG:-24}"; _eta_label="7-Day Window" ;;
            *) continue ;;
        esac
        local eta_info
        eta_info=$(cu_eta_projection "$_eta_field" "$_eta_avg" 2>/dev/null || true)
        if [ -n "$eta_info" ]; then
            local rate eta_hours eta_secs before_reset
            read -r rate eta_hours eta_secs before_reset <<< "$eta_info"
            local eta_dur
            eta_dur=$(cu_fmt_duration "${eta_secs:-0}")
            [ -n "$any_output" ] && printf "\n"
            printf "%s\n" "$_eta_label"
            printf "  Rate: +%s%%/hour\n" "${rate:-0}"
            printf "  ETA to 100%%: ~%s\n" "$eta_dur"
            [ "${before_reset:-}" = "1" ] && printf "  %sWARNING: Projected to hit limit BEFORE reset%s\n" "$(cu_color "$CU_RED")" "$(cu_reset)"
            any_output=1
        fi
    done
    [ -z "$any_output" ] && echo "Insufficient history data for projection."
}

cmd_fetch() {
    parse_flags "$@"
    echo "Fetching usage data..."
    if cu_fetch "force"; then
        local data
        data=$(cu_read_cache)
        cu_history_record "$data"
        echo "OK. 5h: $(cu_get_five_hour_pct "$data")% | 7d: $(cu_get_seven_day_pct "$data")%"
        cu_history_prune
    else
        echo "Failed to fetch usage data." >&2
        return 1
    fi
}

cmd_history() {
    parse_flags "$@"
    local tier="${CU_OPT_TIER:-}"
    if [ -n "$tier" ]; then
        case "$tier" in
            short)
                if [ -f "$CU_HISTORY_SHORT" ]; then
                    cat "$CU_HISTORY_SHORT"
                else
                    echo "No short-tier history yet. Run 'claude-usage fetch' to start recording." >&2
                fi
                ;;
            long)
                if [ -f "$CU_HISTORY_LONG" ]; then
                    cat "$CU_HISTORY_LONG"
                else
                    echo "No long-tier history yet. Run 'claude-usage fetch' to start recording." >&2
                fi
                ;;
            *)
                echo "Unknown tier: $tier (use short or long)" >&2
                return 1
                ;;
        esac
    else
        if [ ! -f "$CU_HISTORY_SHORT" ] && [ ! -f "$CU_HISTORY_LONG" ]; then
            echo "No history yet. Run 'claude-usage fetch' to start recording." >&2
        else
            cu_history_dump
        fi
    fi
}

cmd_history_view() {
    parse_flags "$@"

    local now
    now=$(cu_now)

    # --- Helper: render a table from a JSONL file ---
    _hv_render_table() {
        local file="$1" hours="$2" show_five="$3"
        local cutoff=$((now - hours * 3600))

        [ -f "$file" ] || return 0

        # Header
        printf "%s%-20s" "$(cu_color "$CU_DIM")" "Time"
        if [ "$show_five" = "1" ]; then
            printf "  %-8s  %-8s  %-8s" "5h %" "Δ 5h" "7d %"
        else
            printf "  %-8s" "7d %"
        fi
        printf "  Change%s\n" "$(cu_reset)"

        printf "%s" "$(cu_color "$CU_DIM")"
        if [ "$show_five" = "1" ]; then
            printf "%-20s  %-8s  %-8s  %-8s  %-6s" "────────────────────" "────────" "────────" "────────" "──────"
        else
            printf "%-20s  %-8s  %-6s" "────────────────────" "────────" "──────"
        fi
        printf "%s\n" "$(cu_reset)"

        local prev_five="" prev_seven=""
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            local ts
            ts=$(echo "$line" | jq -r '.ts' 2>/dev/null)
            [ -z "$ts" ] && continue

            local time_str
            time_str=$(date -d "@$ts" "+%b %d %H:%M" 2>/dev/null || date -r "$ts" "+%b %d %H:%M" 2>/dev/null)

            local seven_val
            seven_val=$(echo "$line" | jq -r '.seven_day.util // empty' 2>/dev/null)

            if [ "$show_five" = "1" ]; then
                local five_val
                five_val=$(echo "$line" | jq -r '.five_hour.util // empty' 2>/dev/null)

                local five_colored seven_colored five_delta="" seven_delta=""
                local five_reset="" seven_reset_flag=""
                if [ -n "$five_val" ]; then
                    five_colored=$(cu_fmt_pct "${five_val%.*}")
                    if [ -n "$prev_five" ]; then
                        local fd
                        fd=$(awk "BEGIN { printf \"%.1f\", $five_val - $prev_five }")
                        if awk "BEGIN { exit ($fd < -5) ? 0 : 1 }"; then
                            five_delta="↻"
                            five_reset="1"
                        else
                            five_delta=$(awk "BEGIN { printf \"%+.1f%%\", $fd }")
                        fi
                    fi
                    prev_five="$five_val"
                else
                    five_colored="$(cu_color "$CU_DIM")--$(cu_reset)"
                fi
                if [ -n "$seven_val" ]; then
                    seven_colored=$(cu_fmt_pct "${seven_val%.*}")
                    if [ -n "$prev_seven" ]; then
                        local sd
                        sd=$(awk "BEGIN { printf \"%.1f\", $seven_val - $prev_seven }")
                        if awk "BEGIN { exit ($sd < -5) ? 0 : 1 }"; then
                            seven_delta="↻"
                            seven_reset_flag="1"
                        else
                            seven_delta=$(awk "BEGIN { printf \"%+.1f%%\", $sd }")
                        fi
                    fi
                    prev_seven="$seven_val"
                else
                    seven_colored="$(cu_color "$CU_DIM")--$(cu_reset)"
                fi

                printf "%-20s  " "$time_str"
                _hv_pad "$five_colored" 8
                local five_delta_color="$CU_AQUA"
                [ "$five_reset" = "1" ] && five_delta_color="$CU_COLOR_RESET_ICON"
                printf "  %s%s%s" "$(cu_color "$five_delta_color")" "$(printf '%-8s' "${five_delta:- }")" "$(cu_reset)"
                printf "  "
                _hv_pad "$seven_colored" 8
                local seven_delta_color="$CU_AQUA"
                [ "$seven_reset_flag" = "1" ] && seven_delta_color="$CU_COLOR_RESET_ICON"
                printf "  %s%s%s\n" "$(cu_color "$seven_delta_color")" "${seven_delta:- }" "$(cu_reset)"
            else
                local seven_colored="" seven_delta="" seven_reset_flag=""
                if [ -n "$seven_val" ]; then
                    seven_colored=$(cu_fmt_pct "${seven_val%.*}")
                    if [ -n "$prev_seven" ]; then
                        local sd
                        sd=$(awk "BEGIN { printf \"%.1f\", $seven_val - $prev_seven }")
                        if awk "BEGIN { exit ($sd < -5) ? 0 : 1 }"; then
                            seven_delta="↻"
                            seven_reset_flag="1"
                        else
                            seven_delta=$(awk "BEGIN { printf \"%+.1f%%\", $sd }")
                        fi
                    fi
                    prev_seven="$seven_val"
                else
                    seven_colored="$(cu_color "$CU_DIM")--$(cu_reset)"
                fi

                printf "%-20s  " "$time_str"
                _hv_pad "$seven_colored" 8
                local seven_delta_color="$CU_AQUA"
                [ "$seven_reset_flag" = "1" ] && seven_delta_color="$CU_COLOR_RESET_ICON"
                printf "  %s%s%s\n" "$(cu_color "$seven_delta_color")" "${seven_delta:- }" "$(cu_reset)"
            fi
        done < <(jq -c --argjson cutoff "$cutoff" 'select(.ts >= $cutoff)' "$file" 2>/dev/null)
    }

    # Helper: print colored string then pad to width
    _hv_pad() {
        printf "%s" "$1"
        local vlen
        vlen=$(cu_visible_len "$1")
        [ "$vlen" -lt "$2" ] && printf "%*s" $(($2 - vlen)) ""
    }

    # --- Short tier (recent, fine-grained) ---
    if [ -f "$CU_HISTORY_SHORT" ]; then
        local short_hours="${CU_OPT_HOURS:-36}"
        printf "%s━━━ Recent (5-min intervals, last %sh) ━━━%s\n" \
            "$(cu_color "$CU_FG")" "$short_hours" "$(cu_reset)"
        _hv_render_table "$CU_HISTORY_SHORT" "$short_hours" "1"

        echo ""
        printf "%sBurn rate (5h): %s" "$(cu_color "$CU_DIM")" "$(cu_reset)"
        local spark5
        spark5=$(cu_sparkline_from_history "five_hour" "$short_hours" 40 "braille" "short" 2>/dev/null || true)
        printf "%s%s%s\n" "$(cu_color "$CU_COLOR_SPARKLINE")" "${spark5:-  (no data)}" "$(cu_reset)"
    fi

    # --- Long tier (historical, hourly) ---
    if [ -f "$CU_HISTORY_LONG" ]; then
        local long_hours="${CU_OPT_HOURS:-168}"
        [ -f "$CU_HISTORY_SHORT" ] && echo ""
        printf "%s━━━ History (hourly, last %sd) ━━━%s\n" \
            "$(cu_color "$CU_FG")" "$((long_hours / 24))" "$(cu_reset)"
        _hv_render_table "$CU_HISTORY_LONG" "$long_hours" "0"

        echo ""
        printf "%sBurn rate (7d): %s" "$(cu_color "$CU_DIM")" "$(cu_reset)"
        local spark7
        spark7=$(cu_sparkline_from_history "seven_day" "$long_hours" 40 "braille" "long" 2>/dev/null || true)
        printf "%s%s%s\n" "$(cu_color "$CU_COLOR_SPARKLINE")" "${spark7:-  (no data)}" "$(cu_reset)"
    fi

    if [ ! -f "$CU_HISTORY_SHORT" ] && [ ! -f "$CU_HISTORY_LONG" ]; then
        echo "No history yet. Run 'claude-usage fetch' to start recording." >&2
        return 1
    fi
}

cmd_debug_template() {
    parse_flags "$@"

    if [ "${CU_OPT_NO_FETCH:-}" != "1" ]; then
        if cu_fetch; then
            local cache_data
            cache_data=$(cu_read_cache)
            [ -n "$cache_data" ] && cu_history_record "$cache_data"
        fi
    fi

    local data
    data=$(cu_read_cache)
    if [ -z "$data" ]; then
        echo "No cached usage data. Run 'claude-usage fetch' first." >&2
        return 1
    fi

    local util reset_at secs_to_reset
    util=$(echo "$data" | jq -r '.seven_day.utilization // 0')
    reset_at=$(echo "$data" | jq -r '.seven_day.resets_at // ""')
    if [ -z "$reset_at" ]; then
        echo "No seven_day.resets_at in cache — cannot debug template." >&2
        return 1
    fi
    secs_to_reset=$(cu_secs_until_reset "$reset_at")
    if [ "${secs_to_reset:-0}" -le 0 ]; then
        echo "seven_day reset is at or in the past — nothing to project." >&2
        return 1
    fi

    cu_debug_template_seven_day "${util%.*}" "$secs_to_reset"
}

cmd_install_hook() {
    parse_flags "$@"
    local settings_file="${CLAUDE_CONFIG_DIR:-$HOME/.claude}/settings.json"
    local cmd
    # Determine command path
    cmd="$(cd "$SCRIPT_DIR" && pwd)/claude-usage"

    # Ensure settings file exists
    mkdir -p "$(dirname "$settings_file")"
    if [ ! -f "$settings_file" ]; then
        echo '{}' > "$settings_file"
    fi

    # Use jq to set the statusLine type and command
    local tmp="${settings_file}.tmp"
    if jq --arg cmd "$cmd statusline" '.statusLine.type = "command" | .statusLine.command = $cmd' "$settings_file" > "$tmp"; then
        mv "$tmp" "$settings_file"
    else
        rm -f "$tmp"
        echo "Failed to update settings (invalid JSON?)" >&2
        return 1
    fi

    echo "Configured Claude Code statusline:"
    echo "  command: $cmd statusline"
    echo "  settings: $settings_file"
}

cmd_help() {
    cat <<'EOF'
claude-usage - Claude API usage monitor with history and projections

Usage: claude-usage [command] [flags]

Commands:
  show          Full dashboard (default)
  statusline    Claude Code single-line output (reads workspace JSON from stdin)
  sparkline     Compact sparkline string only
  eta           ETA projection line
  fetch         Force-fetch + record history
  history       Dump raw JSONL history
  history-view  Formatted history table with sparklines (alias: hv)
  debug-template  Trace the seasonal-template ETA (alias: dt)
  install-hook  Configure ~/.claude/settings.json

Flags:
  --no-color       Disable color output
  --no-fetch       Skip API fetch, use cached data
  --data-dir PATH  Override data directory
  --cache-dir PATH Override cache directory
  --width N        Sparkline/bar width
  --hours N        History window in hours
  --braille        Use compact Braille sparkline (2 data points per char)
  --multiline      Multi-line statusline (progress bars + sparkline)
  --windows LIST   Comma-separated windows: five_hour,seven_day (default: both)
  --modules LIST   Comma-separated modules: bar,pct,sparkline,rate,eta,reset
  --sparkline-type TYPE  braille (default) or block
  --bar-width N    Progress bar width (default: 10, multiline only)
  --tier T         History tier: short (5-min, 36h) or long (hourly, 1yr)

Modules:
  bar         Progress bar (multiline only, skipped in single-line)
  pct         Color-coded percentage
  sparkline   Braille or block sparkline from history
  rate        Burn rate per moving average window
  eta         Time to cap projection
  reset       Reset countdown or date

Environment:
  CU_WINDOWS          Windows to show (default: five_hour,seven_day)
  CU_MODULES          Modules to show (default: per mode, see docs)
  CU_SPARKLINE_TYPE   braille or block (default: braille)
  CU_BAR_WIDTH        Progress bar width (default: 10)
  CU_ETA_5H_AVG       Moving avg window for 5h ETA in hours (default: 1)
  CU_ETA_7D_AVG       Moving avg window for 7d ETA in hours (default: 24)
  CU_COLOR_SPARKLINE  ANSI code for sparkline chars
  CU_COLOR_RATE       ANSI code for burn rate text
  CU_COLOR_ETA        ANSI code for ETA duration
  CU_COLOR_RESET      ANSI code for reset value text
  CU_COLOR_RESET_ICON ANSI code for reset arrow
  CU_COLOR_LABEL      ANSI code for 5h/7d labels
  CU_COLOR_DIR        ANSI code for directory name
  CU_COLOR_BRANCH     ANSI code for git branch
  CU_COLOR_WARN       ANSI code for before-reset warning
  CU_UPDATE_CHECK     Enable update check (default: 1, set 0 to disable)
  CU_UPDATE_TTL       Update check cache TTL in seconds (default: 3600)
EOF
}

# Main dispatch
subcommand="${1:-show}"
shift || true

case "$subcommand" in
    show)           cmd_show "$@" ;;
    statusline)     cmd_statusline "$@" ;;
    sparkline)      cmd_sparkline "$@" ;;
    eta)            cmd_eta "$@" ;;
    fetch)          cmd_fetch "$@" ;;
    history)        cmd_history "$@" ;;
    history-view|hv) cmd_history_view "$@" ;;
    debug-template|dt) cmd_debug_template "$@" ;;
    install-hook)   cmd_install_hook "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        echo "Unknown command: $subcommand" >&2
        cmd_help >&2
        exit 1
        ;;
esac
